# ─── Application ─────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-me-super-secret-key-in-production

# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://banking_user:banking_pass@localhost:5432/banking_db
# Pour SQLite en dev (remplacer DATABASE_URL) :
# DATABASE_URL=sqlite:///banking.db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-key-in-production
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 minutes
JWT_REFRESH_TOKEN_EXPIRES=604800    # 7 jours

# ─── Sécurité ────────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=1800               # 30 minutes en secondes
BCRYPT_LOG_ROUNDS=12

# ─── Plafonds par défaut (XAF) ───────────────────────────────────────────────
DEFAULT_DAILY_WITHDRAWAL_LIMIT=500000
DEFAULT_DAILY_DEPOSIT_LIMIT=5000000
DEFAULT_TRANSFER_LIMIT=2000000
HIGH_VALUE_THRESHOLD=1000000        # Seuil validation superviseur
